# Copie ce fichier en .env puis remplis-le avec tes vraies valeurs.
# .env est gitignoré, pas .env.example — donc ne mets JAMAIS de secret ici.

# ---- Identifiants Outlook / Microsoft 365 ----
OUTLOOK_EMAIL=prenom.nom@lacatholille.fr
OUTLOOK_PASSWORD=ton_mot_de_passe

# ---- Serveur SMTP ----
SMTP_HOST=smtp.office365.com
SMTP_PORT=587

# ---- Infos personnelles (injectées dans les templates) ----
NOM_COMPLET=Prénom NOM
TELEPHONE=06 XX XX XX XX
CV_URL=https://github.com/TON_USER/CV/blob/main/cv.pdf
GITHUB=https://github.com/TON_USER
LINKEDIN=https://www.linkedin.com/in/ton-profil/
# Repo GitHub du script (crée-le public, le code du script = preuve du skill)
SCRIPT_URL=https://github.com/TON_USER/script-alternance

# ---- Sécurité anti-spam ----
PAUSE_SECONDES=90
MAX_PAR_JOUR=25
