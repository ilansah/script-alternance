# Copie ce fichier en .env puis remplis-le avec tes vraies valeurs.
# .env est gitignoré, pas .env.example — donc ne mets JAMAIS de secret ici.

# ---- Identifiants SMTP ----
# Recommandé : Gmail avec mot de passe d'application (2FA activée au préalable).
# Outlook/M365 d'école = souvent bloqué (basic SMTP AUTH désactivé).
OUTLOOK_EMAIL=ton.gmail@gmail.com
OUTLOOK_PASSWORD=xxxx xxxx xxxx xxxx

# ---- Serveur SMTP ----
# Gmail : smtp.gmail.com port 587
# Outlook/M365 : smtp.office365.com port 587 (souvent bloqué)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ---- Reply-To : où les réponses arriveront (utile si tu envoies depuis Gmail
# mais veux que les réponses aillent sur ton adresse école). Laisse vide sinon.
REPLY_TO=prenom.nom@lacatholille.fr

# ---- Infos personnelles (injectées dans les templates) ----
NOM_COMPLET=Prénom NOM
TELEPHONE=06 XX XX XX XX
CV_URL=https://github.com/TON_USER/CV/blob/main/cv.pdf
GITHUB=https://github.com/TON_USER
LINKEDIN=https://www.linkedin.com/in/ton-profil/
SCRIPT_URL=https://github.com/TON_USER/script-alternance

# ---- Sécurité anti-spam ----
PAUSE_SECONDES=90
MAX_PAR_JOUR=25
